{
  "name": "db-bitable-sidebar-plugin",
  "version": "1.0.0",
  "type": "module",
  "description": "数据库同步插件，支持 MySQL/PostgreSQL/MongoDB 同步到飞书多维表格",
  "scripts": {
    "dev": "vite",
    "start": "npm run dev",
    "cf:dev": "wrangler dev --config wrangler-db.toml",
    "cf:deploy": "wrangler deploy --config wrangler-db.toml",
    "cf:dev:weread": "wrangler dev --config wrangler.toml",
    "cf:deploy:weread": "wrangler deploy --config wrangler.toml",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "",
  "output": "dist",
  "license": "ISC",
  "devDependencies": {
    "@types/jquery": "^3.5.16",
    "sass": "^1.63.6",
    "typescript": "^4.7.4",
    "vite": "^3.0.4",
    "wrangler": "^4.76.0"
  },
  "dependencies": {
    "@lark-base-open/js-sdk": "^0.5.0",
    "bootstrap": "^5.3.3",
    "jquery": "^3.7.1",
    "mongodb": "^6.12.0",
    "mysql2": "^3.15.3",
    "pg": "^8.13.0",
    "postgres": "^3.4.8",
    "reset-css": "^5.0.1"
  }
}
